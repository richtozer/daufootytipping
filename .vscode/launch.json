{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
  
    {
      "name": "Start JSON-SERVER - 2024-3rounds",
      "preLaunchTask": "LaunchJSONServer",
      "type": "node",
      "request": "launch"
    },
    {
      "name": "Debug TypeScript",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/functions/src/test.ts",
      "args": [],
      "console": "integratedTerminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:6001",
      "webRoot": "${workspaceFolder}",
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Debug Functions",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "start firebase emulator",
      "postDebugTask": "stop firebase emulator"
    },
    // WEB_APP_CHECK_DEBUG_TOKEN is read from the VS Code process environment.
    // A local .env file is not loaded automatically for Dart/Flutter launches.
    // Start VS Code from a shell that has exported the variable, or set it in your shell profile.
    {
      "name": "Flutter Web (Chrome) + Firebase emulators (seed RTDB)",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "deviceId": "chrome",
      "program": "lib/main.dart",
      "preLaunchTask": "seed firebase rtdb emulator from extract",
      "postDebugTask": "stop firebase emulator",
      "toolArgs": [
        "--dart-define=USE_FIREBASE_EMULATORS=true",
        "--dart-define=FIREBASE_EMULATOR_HOST=localhost",
        "--dart-define=WEB_APP_CHECK_DEBUG_TOKEN=${env:WEB_APP_CHECK_DEBUG_TOKEN}"
      ]
    },
    {
      "name": "Flutter Web (Chrome) with fixed App Check token",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "deviceId": "chrome",
      "program": "lib/main.dart",
      "toolArgs": [
        "--dart-define=USE_FIREBASE_EMULATORS=false",
        "--dart-define=WEB_APP_CHECK_DEBUG_TOKEN=${env:WEB_APP_CHECK_DEBUG_TOKEN}"
      ]
    },
    {
      "name": "Flutter iPhone 16 Pro + Startup Profiling",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "deviceId": "05EC8C12-11FF-4BEB-9016-B613947116A9",
      "program": "lib/main.dart",
      "toolArgs": [
        "--dart-define=STARTUP_PROFILING=true"
      ]
    }
  ]
}
