{
  "version": "2.0.0",
  "tasks": [
    {
      "label": " ",
      "type": "shell",
      "command": "json-server --watch ./test/data/fixture-2024-3rounds.json"
    },
    {
      "label": "start firebase emulator",
      "type": "shell",
      "isBackground": true,
      // (1) This autocompiles if there is any code change and effective immediately.
      // (2) The single '&' ensures tsc -w (used in run build) will not block the emulator to start
      // (3) --inspect-function allows debugger to be attached
      "command": "npm --prefix ./functions run build -- -w & firebase emulators:start --inspect-functions",
      "presentation": { "reveal": "silent", "close": true },
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "line": 1,
              "column": 1,
              "message": 1
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": { "regexp": "." },
            "endsPattern": { "regexp": "." }
          }
        }
      ]
    },
    {
      "label": "start firebase emulators (web debug seeded)",
      "type": "shell",
      "isBackground": true,
      // Starts function TypeScript watch mode and Firebase emulators for local app debugging.
      "command": "npm --prefix ./functions run build -- -w & firebase emulators:start --inspect-functions",
      "presentation": { "reveal": "silent", "close": true },
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "line": 1,
              "column": 1,
              "message": 1
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": { "regexp": "." },
            "endsPattern": { "regexp": ".*All emulators ready.*" }
          }
        }
      ]
    },
    {
      "label": "seed firebase rtdb emulator from extract",
      "type": "shell",
      "dependsOn": ["start firebase emulators (web debug seeded)"],
      "dependsOrder": "sequence",
      // Replaces the emulator RTDB contents with the selected JSON extract.
      "command": "bash ./scripts/seed_rtdb_emulator.sh \"${workspaceFolder}/${input:rtdbExtractPath}\"",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "stop firebase emulator",
      "type": "shell",
      "command": "bash ./scripts/stop_firebase_emulators_vscode.sh",
      "presentation": { "reveal": "silent", "panel": "shared" }
    }
  ],
  "inputs": [
    {
      "id": "rtdbExtractPath",
      "type": "promptString",
      "description": "Relative path to the RTDB JSON extract to seed into the emulator",
      "default": "test/data/dau-footy-tipping-f8a42-default-rtdb-export-end-of-comp-2025.json"
    }
  ]
}
